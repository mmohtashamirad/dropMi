{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug sondrop server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/sondrop",
      "cwd": "${workspaceFolder}",
      "args": [
        "-upload-tmp-dir",
        "./build/tmp/",
        "-upload-dir",
        "./build/upload",
        "-log-level",
        "debug",
        "-addr",
        ":8080"
      ]
    }
  ]
}